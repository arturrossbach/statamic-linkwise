{
    "name": "arturrossbach/linkwise",
    "type": "statamic-addon",
    "description": "Intelligent internal linking assistant for Statamic — find broken links, suggest internal links, manage rel attributes, and bulk-replace URLs.",
    "license": "proprietary",
    "keywords": [
        "statamic",
        "statamic-addon",
        "internal-linking",
        "seo",
        "broken-links",
        "url-changer",
        "auto-linking",
        "content"
    ],
    "authors": [
        {
            "name": "Artur Roßbach",
            "email": "linkwise.support@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/arturrossbach/statamic-linkwise",
    "support": {
        "issues": "https://github.com/arturrossbach/statamic-linkwise/issues",
        "source": "https://github.com/arturrossbach/statamic-linkwise",
        "email": "linkwise.support@gmail.com"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "statamic/cms": "^6.0",
        "wamania/php-stemmer": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.8"
    },
    "autoload": {
        "psr-4": {
            "Arturrossbach\\Linkwise\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arturrossbach\\Linkwise\\Tests\\": "tests"
        }
    },
    "extra": {
        "statamic": {
            "name": "Linkwise",
            "description": "Intelligent internal linking assistant for Statamic — find broken links, suggest internal links, manage rel attributes, and bulk-replace URLs."
        },
        "laravel": {
            "providers": [
                "Arturrossbach\\Linkwise\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/Unit"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
